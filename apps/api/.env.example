# Ambiente
NODE_ENV=development
PORT=3333
LOG_LEVEL=info

# Banco de dados (corresponde ao docker-compose.yml na raiz)
DATABASE_URL=postgresql://rpx:rpx@localhost:5433/rpx_expert?schema=public

# JWT — gerar segredos fortes em produção (>=32 chars). Exemplo de geração:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-trocar-em-prod-com-no-minimo-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-trocar-em-prod-com-no-minimo-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Seed inicial (criado por `pnpm --filter api db:seed`)
SEED_UNIT_NAME=RPX Expert — Matriz
SEED_UNIT_TIMEZONE=America/Sao_Paulo
SEED_ADMIN_EMAIL=admin@rpxexpert.local
SEED_ADMIN_PASSWORD=RpxAdmin@2026
SEED_ADMIN_FULL_NAME=Administrador RPX

# Integração iDFace — segredo compartilhado enviado pelo equipamento no
# header `X-IDFace-Secret`. Em produção, gerar e armazenar em secret manager.
IDFACE_WEBHOOK_SECRET=dev-idface-secret-trocar-em-prod
