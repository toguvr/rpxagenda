// Schema RPX Expert
// Fonte da verdade técnica: CLAUDE.md §5 e §6.
// Convenção de IDs: cuid v1 (default do Prisma) — CLAUDE.md §7.1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROFESSIONAL
  PATIENT
}

enum ServiceType {
  FISIO
  MUSCULACAO
  RPG
  PILATES
  AVALIACAO
}

enum PlanType {
  PACKAGE
  SUBSCRIPTION
}

enum PlanStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum ScheduleExceptionType {
  CLOSED
  CUSTOM
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("America/Sao_Paulo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  services           Service[]
  equipments         Equipment[]
  professionals      Professional[]
  patients           Patient[]
  businessHours      BusinessHours[]
  scheduleExceptions ScheduleException[]
  plans              Plan[]

  @@map("units")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole
  unitId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  unit          Unit           @relation(fields: [unitId], references: [id])
  refreshTokens RefreshToken[]
  professional  Professional?
  patient       Patient?

  @@index([unitId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ----- Catálogo -----

model Service {
  id                       String      @id @default(cuid())
  unitId                   String
  name                     String
  type                     ServiceType
  durationMinutes          Int
  slotCapacity             Int         @default(1)
  cancellationLeadMinutes  Int         @default(240)
  schedulingLeadMinutes    Int         @default(60)
  checkInWindowBeforeMin   Int         @default(30)
  checkInWindowAfterMin    Int         @default(15)
  acceptedPlanType         PlanType
  active                   Boolean     @default(true)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  unit               Unit                  @relation(fields: [unitId], references: [id])
  equipments         ServiceEquipment[]
  professionalLinks  ProfessionalService[]
  plans              Plan[]
  businessHours      BusinessHours[]

  @@unique([unitId, name])
  @@index([unitId, active])
  @@map("services")
}

model Equipment {
  id            String   @id @default(cuid())
  unitId        String
  name          String
  totalQuantity Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  unit     Unit               @relation(fields: [unitId], references: [id])
  services ServiceEquipment[]

  @@unique([unitId, name])
  @@index([unitId, active])
  @@map("equipments")
}

model ServiceEquipment {
  serviceId   String
  equipmentId String
  createdAt   DateTime @default(now())

  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([serviceId, equipmentId])
  @@index([equipmentId])
  @@map("service_equipments")
}

// ----- Pessoas -----

model Professional {
  id        String   @id @default(cuid())
  unitId    String
  userId    String   @unique
  fullName  String
  registry  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit     Unit                  @relation(fields: [unitId], references: [id])
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  services ProfessionalService[]

  @@unique([unitId, registry])
  @@index([unitId, active])
  @@map("professionals")
}

model ProfessionalService {
  professionalId String
  serviceId      String
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@index([serviceId])
  @@map("professional_services")
}

model Patient {
  id                String   @id @default(cuid())
  unitId            String
  userId            String?  @unique
  fullName          String
  cpf               String
  birthDate         DateTime
  phone             String
  email             String?
  emergencyContact  String?
  notes             String?
  idfaceUserId      String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  unit    Unit            @relation(fields: [unitId], references: [id])
  user    User?           @relation(fields: [userId], references: [id])
  invites PatientInvite[]
  plans   Plan[]

  @@unique([unitId, cpf])
  @@index([unitId, fullName])
  @@map("patients")
}

model PatientInvite {
  id         String    @id @default(cuid())
  patientId  String
  tokenHash  String    @unique
  expiresAt  DateTime
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([expiresAt])
  @@map("patient_invites")
}

// ----- Grade de horários -----

/// Horário de funcionamento de um serviço por dia da semana (0=domingo .. 6=sábado).
/// Cada serviço tem sua própria grade — ex: musculação 06:00-22:00, fisio 08:00-18:00.
/// Múltiplas janelas no mesmo dia para o mesmo serviço (manhã + tarde) são permitidas.
model BusinessHours {
  id        String   @id @default(cuid())
  unitId    String
  serviceId String
  weekday   Int      // 0=domingo .. 6=sábado
  opensAt   String   // HH:MM no fuso da unidade
  closesAt  String   // HH:MM no fuso da unidade
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit    Unit    @relation(fields: [unitId], references: [id])
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([unitId, serviceId, weekday])
  @@map("business_hours")
}

/// Exceções pontuais ao calendário: fechamento total (feriado) ou horário customizado em uma data.
model ScheduleException {
  id        String                @id @default(cuid())
  unitId    String
  date      DateTime              @db.Date   // dia específico (sem hora), no fuso da unidade
  type      ScheduleExceptionType
  opensAt   String?
  closesAt  String?
  reason    String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([unitId, date])
  @@index([unitId, date])
  @@map("schedule_exceptions")
}

// ----- Planos comerciais -----

/// Contrato comercial entre paciente e serviço. Dois tipos:
/// - PACKAGE: totalSessions + remainingSessions + validUntil
/// - SUBSCRIPTION: weeklyQuota + (futuramente) pagarmeSubscriptionId + nextBillingAt
model Plan {
  id        String     @id @default(cuid())
  unitId    String
  patientId String
  serviceId String
  type      PlanType
  status    PlanStatus @default(ACTIVE)

  // PACKAGE
  totalSessions     Int?
  remainingSessions Int?
  validUntil        DateTime?

  // SUBSCRIPTION
  weeklyQuota           Int?
  pagarmeSubscriptionId String?
  nextBillingAt         DateTime?

  startsAt  DateTime @default(now())
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit    Unit    @relation(fields: [unitId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([unitId, patientId, status])
  @@index([unitId, serviceId, status])
  @@map("plans")
}
