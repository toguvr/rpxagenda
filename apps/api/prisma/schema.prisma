// Schema RPX Expert
// Fonte da verdade técnica: CLAUDE.md §5 e §6.
// Convenção de IDs: cuid v1 (default do Prisma) — CLAUDE.md §7.1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROFESSIONAL
  PATIENT
}

enum ServiceType {
  FISIO
  MUSCULACAO
  RPG
  PILATES
  AVALIACAO
}

enum PlanType {
  PACKAGE
  SUBSCRIPTION
}

enum PlanStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum ScheduleExceptionType {
  CLOSED
  CUSTOM
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum IdfaceEventOutcome {
  CHECKIN_OK
  CHECKIN_OK_REVERTED_NO_SHOW
  NO_APPOINTMENT_IN_WINDOW
  PATIENT_NOT_FOUND
  ALREADY_CHECKED_IN
}

enum IdfaceEnrollmentStatus {
  PENDING
  REGISTERED
  FAILED
}

enum IdfaceCommandStep {
  DESTROY
  CREATE_USER
  SET_IMAGE
}

enum IdfaceCommandStatus {
  PENDING
  DISPATCHED
  DONE
  FAILED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BOLETO
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PAID
  PENDING
  REFUNDED
  FAILED
}

enum ExpenseCategory {
  RENT
  PAYROLL
  SUPPLIES
  EQUIPMENT
  UTILITIES
  TAXES
  MARKETING
  OTHER
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("America/Sao_Paulo")
  /// Próximo `user_id` (int64) a ser gerado para enrollment no iDFace desta unidade.
  /// Atualizado atomicamente em UPDATE ... RETURNING ao criar uma enrollment.
  nextIdfaceUserId Int @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  services           Service[]
  equipments         Equipment[]
  professionals      Professional[]
  patients           Patient[]
  businessHours      BusinessHours[]
  scheduleExceptions ScheduleException[]
  plans              Plan[]
  appointments       Appointment[]
  idfaceEvents       IdfaceEvent[]
  idfaceDevices      IdfaceDevice[]
  idfaceEnrollments  IdfaceEnrollment[]
  idfaceCommands     IdfaceCommand[]
  protocols          Protocol[]
  medicalRecords     MedicalRecord[]
  payments           Payment[]
  expenses           Expense[]

  @@map("units")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole
  unitId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  unit           Unit            @relation(fields: [unitId], references: [id])
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]
  professional   Professional?
  patient        Patient?

  @@index([unitId])
  @@map("users")
}

/// Token de redefinição de senha (esqueci a senha). Guardamos apenas o hash do
/// token; o token plain só trafega no link enviado por e-mail. Idempotente por
/// hash; expira em minutos e é consumido (usedAt) ao redefinir.
model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ----- Catálogo -----

model Service {
  id                       String      @id @default(cuid())
  unitId                   String
  name                     String
  type                     ServiceType
  durationMinutes          Int
  slotCapacity             Int         @default(1)
  cancellationLeadMinutes  Int         @default(240)
  schedulingLeadMinutes    Int         @default(60)
  checkInWindowBeforeMin   Int         @default(30)
  checkInWindowAfterMin    Int         @default(15)
  /// Minutos depois de endsAt em que o job de no-show ainda aguarda o check-in
  /// antes de marcar o agendamento como NO_SHOW automaticamente.
  noShowGraceMinutes       Int         @default(15)
  acceptedPlanType         PlanType
  /// Preço sugerido em centavos (BRL). Pré-preenche o valor ao criar um plano.
  suggestedPriceCents      Int?
  active                   Boolean     @default(true)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  unit               Unit                  @relation(fields: [unitId], references: [id])
  equipments         ServiceEquipment[]
  professionalLinks  ProfessionalService[]
  plans              Plan[]
  businessHours      BusinessHours[]
  appointments       Appointment[]
  scheduleExceptions ScheduleException[]

  @@unique([unitId, name])
  @@index([unitId, active])
  @@map("services")
}

model Equipment {
  id            String   @id @default(cuid())
  unitId        String
  name          String
  totalQuantity Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  unit         Unit                   @relation(fields: [unitId], references: [id])
  services     ServiceEquipment[]
  appointments AppointmentEquipment[]
  protocols    ProtocolEquipment[]

  @@unique([unitId, name])
  @@index([unitId, active])
  @@map("equipments")
}

model ServiceEquipment {
  serviceId   String
  equipmentId String
  createdAt   DateTime @default(now())

  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([serviceId, equipmentId])
  @@index([equipmentId])
  @@map("service_equipments")
}

// ----- Pessoas -----

model Professional {
  id        String   @id @default(cuid())
  unitId    String
  userId    String   @unique
  fullName  String
  registry  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit           Unit                  @relation(fields: [unitId], references: [id])
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  services       ProfessionalService[]
  appointments   Appointment[]
  protocols      Protocol[]
  medicalRecords MedicalRecord[]

  @@unique([unitId, registry])
  @@index([unitId, active])
  @@map("professionals")
}

model ProfessionalService {
  professionalId String
  serviceId      String
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@index([serviceId])
  @@map("professional_services")
}

model Patient {
  id                String   @id @default(cuid())
  unitId            String
  userId            String?  @unique
  fullName          String
  cpf               String
  birthDate         DateTime
  phone             String
  email             String?
  emergencyContact  String?
  notes             String?
  // Campos opcionais (contexto clínico).
  profession        String?
  activity          String?
  // Apelido/referência interna — visível apenas para ADMIN (oculto de PROFESSIONAL/PATIENT).
  adminReference    String?
  // Chave (object key) da foto do paciente no bucket S3. URL é assinada sob demanda.
  photoKey          String?
  /// ID interno do paciente no equipamento iDFace (gerado por nós ao enrolar).
  /// Único por unidade — cada totem tem sua própria numeração.
  idfaceUserId      Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  unit              Unit                @relation(fields: [unitId], references: [id])
  user              User?               @relation(fields: [userId], references: [id])
  invites           PatientInvite[]
  plans             Plan[]
  appointments      Appointment[]
  idfaceEvents      IdfaceEvent[]
  idfaceEnrollments IdfaceEnrollment[]
  idfaceCommands    IdfaceCommand[]
  protocols         Protocol[]
  medicalRecords    MedicalRecord[]
  payments          Payment[]

  @@unique([unitId, cpf])
  @@unique([unitId, idfaceUserId])
  @@index([unitId, fullName])
  @@map("patients")
}

model PatientInvite {
  id         String    @id @default(cuid())
  patientId  String
  tokenHash  String    @unique
  expiresAt  DateTime
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([expiresAt])
  @@map("patient_invites")
}

// ----- Grade de horários -----

/// Horário de funcionamento de um serviço por dia da semana (0=domingo .. 6=sábado).
/// Cada serviço tem sua própria grade — ex: musculação 06:00-22:00, fisio 08:00-18:00.
/// Múltiplas janelas no mesmo dia para o mesmo serviço (manhã + tarde) são permitidas.
model BusinessHours {
  id        String   @id @default(cuid())
  unitId    String
  serviceId String
  weekday   Int      // 0=domingo .. 6=sábado
  opensAt   String   // HH:MM no fuso da unidade
  closesAt  String   // HH:MM no fuso da unidade
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit    Unit    @relation(fields: [unitId], references: [id])
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([unitId, serviceId, weekday])
  @@map("business_hours")
}

/// Exceções pontuais ao calendário: fechamento total (feriado) ou horário customizado em uma data.
model ScheduleException {
  id        String                @id @default(cuid())
  unitId    String
  // null = unidade inteira; setado = exceção só para este serviço.
  serviceId String?
  date      DateTime              @db.Date   // dia específico (sem hora), no fuso da unidade
  type      ScheduleExceptionType
  opensAt   String?
  closesAt  String?
  reason    String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  unit    Unit     @relation(fields: [unitId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([unitId, date, serviceId])
  @@index([unitId, date])
  @@map("schedule_exceptions")
}

// ----- Planos comerciais -----

/// Contrato comercial entre paciente e serviço. Dois tipos:
/// - PACKAGE: totalSessions + remainingSessions + validUntil
/// - SUBSCRIPTION: weeklyQuota + (futuramente) pagarmeSubscriptionId + nextBillingAt
model Plan {
  id        String     @id @default(cuid())
  unitId    String
  patientId String
  serviceId String
  type      PlanType
  status    PlanStatus @default(ACTIVE)

  /// Valor combinado com o paciente em centavos (BRL). Pré-preenchido pelo preço
  /// sugerido do serviço, editável (descontos etc).
  priceCents Int?

  // PACKAGE
  totalSessions     Int?
  remainingSessions Int?
  validUntil        DateTime?

  // SUBSCRIPTION
  weeklyQuota           Int?
  pagarmeSubscriptionId String?
  nextBillingAt         DateTime?

  startsAt  DateTime @default(now())
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit         Unit          @relation(fields: [unitId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id])
  appointments Appointment[]
  protocols    Protocol[]
  payments     Payment[]

  @@index([unitId, patientId, status])
  @@index([unitId, serviceId, status])
  @@map("plans")
}

// ----- Agendamentos -----

/// Slot reservado para um paciente em um horário, com um serviço e equipamentos opcionais.
/// CLAUDE.md §4.3 (regra de capacidade) é validada na criação via $transaction SERIALIZABLE.
model Appointment {
  id                 String            @id @default(cuid())
  unitId             String
  patientId          String
  serviceId          String
  // null = agendamento avulso (sem plano) — usado para Avaliação avulsa.
  planId             String?
  professionalId     String?
  startsAt           DateTime
  endsAt             DateTime
  status             AppointmentStatus @default(SCHEDULED)
  /// True quando o agendamento já consumiu uma sessão do plano PACKAGE (ou
  /// é elegível a contar para a quota da SUBSCRIPTION). Setado em true ao criar;
  /// volta para false em cancelamento dentro do prazo (estornando o saldo).
  consumedSession    Boolean           @default(true)
  checkedInAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?
  /// True quando o admin reverteu manualmente um NO_SHOW ou um cancel fora-do-prazo.
  revertedAt         DateTime?
  revertedById       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  unit           Unit                   @relation(fields: [unitId], references: [id])
  patient        Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service        Service                @relation(fields: [serviceId], references: [id])
  plan           Plan?                  @relation(fields: [planId], references: [id])
  professional   Professional?          @relation(fields: [professionalId], references: [id])
  equipments     AppointmentEquipment[]
  idfaceEvents   IdfaceEvent[]
  medicalRecords MedicalRecord[]
  protocols      Protocol[]

  @@index([unitId, serviceId, startsAt, status])
  @@index([unitId, patientId, startsAt])
  @@index([unitId, startsAt, status])
  @@index([planId])
  @@map("appointments")
}

model AppointmentEquipment {
  appointmentId String
  equipmentId   String
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  equipment   Equipment   @relation(fields: [equipmentId], references: [id])

  @@id([appointmentId, equipmentId])
  @@index([equipmentId])
  @@map("appointment_equipments")
}

// ----- Integração iDFace -----

/// Evento de acesso recebido do equipamento iDFace via webhook.
/// Idempotente por (deviceId, eventAt, idfaceUserId) — reenvios devolvem o mesmo registro.
///
/// `unitId` é resolvido a partir do `Patient.idfaceUserId` no momento do processamento.
/// Eventos com paciente não encontrado têm `patientId=null` e `unitId` arbitrário
/// (PREMISSA: nesse cenário gravamos com a primeira unidade encontrada para diagnose;
/// admin investiga via dashboard. O acesso é negado.).
model IdfaceEvent {
  id             String              @id @default(cuid())
  unitId         String
  deviceId       String
  idfaceUserId   String
  eventAt        DateTime
  accessGranted  Boolean
  outcome        IdfaceEventOutcome
  patientId      String?
  appointmentId  String?
  rawPayload     Json
  createdAt      DateTime            @default(now())

  unit        Unit         @relation(fields: [unitId], references: [id])
  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@unique([deviceId, eventAt, idfaceUserId])
  @@index([unitId, eventAt])
  @@index([patientId])
  @@map("idface_events")
}

/// Equipamento iDFace registrado por uma unidade. O `deviceId` é a string que o
/// próprio equipamento envia no Push (configurada na tela do iDFace). Resolve o
/// vínculo deviceId → unidade tanto no Push (fila de comandos) quanto no Access
/// Event (catraca), evitando que um totem libere paciente de outra unidade.
model IdfaceDevice {
  id         String    @id @default(cuid())
  unitId     String
  deviceId   String    @unique
  name       String
  active     Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId, active])
  @@map("idface_devices")
}

/// Ciclo de cadastro de um paciente no iDFace. Criado quando o admin salva a
/// foto; vai a REGISTERED quando o device confirma o último comando da fila.
model IdfaceEnrollment {
  id             String                 @id @default(cuid())
  unitId         String
  patientId      String
  /// Snapshot da photoKey no instante do enrollment (para auditoria / re-enroll).
  photoKey       String
  /// `user_id` (int64) que mandamos no iDFace. Único por unidade.
  assignedUserId Int
  status         IdfaceEnrollmentStatus @default(PENDING)
  registeredAt   DateTime?
  failedAt       DateTime?
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  unit     Unit            @relation(fields: [unitId], references: [id])
  patient  Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  commands IdfaceCommand[]

  @@index([unitId, status])
  @@index([patientId])
  @@map("idface_enrollments")
}

/// Comando enfileirado para o device executar via Push (GET /push → POST /result).
/// Cada `IdfaceEnrollment` gera 2 ou 3 comandos (DESTROY → CREATE_USER → SET_IMAGE).
/// FIFO por unidade. `uuid` é a chave de correlação com o que o device devolve.
model IdfaceCommand {
  id            String              @id @default(cuid())
  unitId        String
  enrollmentId  String
  patientId     String
  step          IdfaceCommandStep
  /// Snapshot do comando como o device receberá (verb, endpoint, body, contentType).
  /// Inclui imagem em base64 no caso de SET_IMAGE.
  payload       Json
  /// UUID que volta no POST /result para correlacionar com este comando.
  uuid          String              @unique
  status        IdfaceCommandStatus @default(PENDING)
  deviceId      String?
  dispatchedAt  DateTime?
  completedAt   DateTime?
  response      Json?
  error         String?
  attempts      Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  unit       Unit             @relation(fields: [unitId], references: [id])
  enrollment IdfaceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  patient    Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([unitId, status, createdAt])
  @@index([enrollmentId])
  @@map("idface_commands")
}

// ----- Prontuário & Protocolo -----

/// Plano clínico definido pelo profissional na avaliação. Liga-se a um Plan
/// comercial; admin pode criar/atualizar enquanto o paciente estiver em
/// tratamento. PREMISSA: 1 protocol ACTIVE por (patientId, planId).
model Protocol {
  id              String   @id @default(cuid())
  unitId          String
  patientId       String
  professionalId  String
  // Plano comercial vinculado — opcional: a avaliação pode ser feita antes da venda do plano.
  planId          String?
  // Agendamento de avaliação que originou este protocolo (opcional).
  appointmentId   String?
  totalSessions   Int
  sessionsPerWeek Int
  diagnosis       String
  observations    String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  unit         Unit                @relation(fields: [unitId], references: [id])
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Professional        @relation(fields: [professionalId], references: [id])
  plan         Plan?               @relation(fields: [planId], references: [id])
  appointment  Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  equipments   ProtocolEquipment[]

  @@index([unitId, patientId, active])
  @@index([planId])
  @@index([appointmentId])
  @@map("protocols")
}

model ProtocolEquipment {
  protocolId  String
  equipmentId String
  createdAt   DateTime @default(now())

  protocol  Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@id([protocolId, equipmentId])
  @@index([equipmentId])
  @@map("protocol_equipments")
}

/// Registro clínico do que aconteceu numa sessão (ou anotação livre).
/// Pode estar ligado a um Appointment específico ou ser uma anotação geral.
/// `attachmentUrls` guarda URLs externas (S3/R2/etc); o upload em si fica
/// para uma sessão futura com IStorageProvider.
model MedicalRecord {
  id              String   @id @default(cuid())
  unitId          String
  patientId       String
  professionalId  String
  appointmentId   String?
  content         String   @db.Text
  attachmentUrls  String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  unit         Unit         @relation(fields: [unitId], references: [id])
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([unitId, patientId, createdAt])
  @@index([appointmentId])
  @@map("medical_records")
}

// ----- Financeiro -----

/// Recebimento (entrada). Lançado manualmente pelo admin; a integração Pagar.me
/// (Fase 6) preencherá `pagarmeChargeId`/`rawWebhook`. Valores em centavos (BRL).
/// `createdById` guarda o admin autor (sem relação, como AuditLog.actorId).
model Payment {
  id              String        @id @default(cuid())
  unitId          String
  planId          String?
  patientId       String?
  amountCents     Int
  method          PaymentMethod
  status          PaymentStatus @default(PAID)
  paidAt          DateTime?
  dueAt           DateTime?
  description     String?
  notes           String?
  pagarmeChargeId String?
  rawWebhook      Json?
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  unit    Unit     @relation(fields: [unitId], references: [id])
  plan    Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([unitId, status])
  @@index([unitId, paidAt])
  @@index([patientId])
  @@index([planId])
  @@map("payments")
}

/// Despesa (saída). Lançada manualmente pelo admin. Valores em centavos (BRL).
model Expense {
  id          String          @id @default(cuid())
  unitId      String
  category    ExpenseCategory
  amountCents Int
  paidAt      DateTime
  description String?
  notes       String?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId, paidAt])
  @@index([unitId, category])
  @@map("expenses")
}
